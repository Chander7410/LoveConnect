# LoveConnect production environment example

# Backend API
SERVER_PORT=8080
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/loveconnect?retryWrites=true&w=majority
APP_CORS_ALLOWED_ORIGINS=https://love-connect-beta.vercel.app,http://localhost:5180,http://127.0.0.1:5180
JWT_SECRET=change-this-to-a-long-random-production-secret
JWT_EXPIRY=86400

# Brevo SMTP email OTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=your-brevo-smtp-login
BREVO_SMTP_PASSWORD=your-brevo-smtp-key
BREVO_API_KEY=your-brevo-api-key
MAIL_FROM=supportloveconnect@gmail.com
SMTP_CONNECTION_TIMEOUT=10000
SMTP_TIMEOUT=10000
SMTP_WRITE_TIMEOUT=10000
APP_DEV_OTP_RESPONSE=false

# Frontend
VITE_API_URL=https://your-backend-domain.com/api
